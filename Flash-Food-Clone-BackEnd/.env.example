MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=FlashFood
MOMO_STORE_NAME=FlashFoodClone
MOMO_REDIRECT_URL=http://localhost:5173/payment-success
MOMO_IPN_URL=http://localhost:4000/api/payment/momo/ipn
